# Evaluation Configuration

model:
  checkpoint: "output/speaker-profiling/best_model"
  name: "microsoft/wavlm-base-plus"
  head_hidden_dim: 256

audio:
  sampling_rate: 16000
  max_duration: 5

evaluation:
  batch_size: 32
  dataloader_num_workers: 2

data:
  clean_test_meta: "/path/to/ViSpeech/metadata/clean_testset.csv"
  clean_test_audio: "/path/to/ViSpeech/clean_testset"
  noisy_test_meta: "/path/to/ViSpeech/metadata/noisy_testset.csv"
  noisy_test_audio: "/path/to/ViSpeech/noisy_testset"
  vimd_path: "nguyendv02/ViMD_Dataset"

output:
  dir: "output/evaluation"
  save_predictions: true
  save_confusion_matrix: true

labels:
  gender:
    Male: 0
    Female: 1
    0: 0
    1: 1
  dialect:
    North: 0
    Central: 1
    South: 2
  region_to_dialect:
    North: 0
    Central: 1
    South: 2

baseline:
  gender:
    clean: 98.73
    noisy: 98.14
  dialect:
    clean: 81.47
    noisy: 74.80
