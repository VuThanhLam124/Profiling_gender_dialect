# Finetune Configuration
# Train full model from raw audio.

model:
  name: "microsoft/wavlm-base-plus"
  num_genders: 2
  num_dialects: 3
  dropout: 0.1
  head_hidden_dim: 256

audio:
  sampling_rate: 16000
  max_duration: 5

training:
  batch_size: 32
  gradient_accumulation_steps: 1
  learning_rate: 5e-5
  num_epochs: 15
  warmup_ratio: 0.125
  weight_decay: 0.0125
  gradient_clip: 0.5
  lr_scheduler: "linear"
  fp16: true
  dataloader_num_workers: 4
  resume_from_checkpoint: null

augmentation:
  enabled: true
  prob: 0.8

loss:
  dialect_weight: 3.0

wandb:
  enabled: false
  api_key: null
  project: "speaker-profiling"
  run_name: null

# source:
#   - "vispeech" (CSV format)
#   - "vimd" (single HuggingFace dataset)
#   - "unified" (merge ViMD + LSVSC + ViSEC)
data:
  source: "vispeech"  # Options: vispeech, vimd, unified

  # ViSpeech
  vispeech_root: "/path/to/ViSpeech"
  train_meta: "/path/to/ViSpeech/metadata/trainset.csv"
  train_audio: "/path/to/ViSpeech/trainset"
  clean_test_meta: "/path/to/ViSpeech/metadata/clean_testset.csv"
  clean_test_audio: "/path/to/ViSpeech/clean_testset"
  noisy_test_meta: "/path/to/ViSpeech/metadata/noisy_testset.csv"
  noisy_test_audio: "/path/to/ViSpeech/noisy_testset"
  val_split: 0.15

  # ViMD
  vimd_path: "nguyendv02/ViMD_Dataset"

  # Unified multi-source training
  unified:
    # Optional explicit source list; leave empty to use all enabled sources below
    enabled_sources: []

    # concat: simply concatenate all train splits
    # balanced_concat: oversample smaller sources to match sampling_probs per epoch
    train_merge_strategy: "balanced_concat"

    # Recommended starting point for cross-dataset robustness
    sampling_probs:
      vimd: 0.4
      lsvsc: 0.4
      visec: 0.2

    vimd:
      enabled: true
      path: "nguyendv02/ViMD_Dataset"

    lsvsc:
      enabled: true
      path: "doof-ferb/LSVSC"
      # Only keep these 3 coarse dialects, then normalize to North/Central/South
      dialect_map:
        northern dialect: North
        central dialect: Central
        southern dialect: South

    visec:
      enabled: true
      path: "hustep-lab/ViSEC"
      # ViSEC only has train split, so we create speaker-disjoint val/test splits
      val_split: 0.1
      test_split: 0.1
      split_seed: 42

output:
  dir: "output/speaker-profiling"
  save_total_limit: 3
  metric_for_best_model: "dialect_acc"

early_stopping:
  patience: 3
  threshold: 0.0025

labels:
  gender:
    Male: 0
    Female: 1
    0: 0
    1: 1
  dialect:
    North: 0
    Central: 1
    South: 2
  region_to_dialect:
    North: 0
    Central: 1
    South: 2

seed: 42
