# Inference Configuration

model:
  checkpoint: "path/to/best_model"
  name: "microsoft/wavlm-base-plus"
  head_hidden_dim: 256

audio:
  sampling_rate: 16000
  max_duration: 5

inference:
  batch_size: 1
  device: "cuda"

input:
  audio_path: null
  audio_dir: null

output:
  dir: "output/predictions"
  save_results: true
  format: "json"

labels:
  gender:
    0: "Male"
    1: "Female"
  dialect:
    0: "North"
    1: "Central"
    2: "South"
